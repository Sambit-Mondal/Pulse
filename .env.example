# Environment Variables for Pulse
# Copy this file to .env and fill in the values

# MongoDB connection string
# For local development: mongodb://localhost:27017/pulse
# For MongoDB Atlas: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/pulse
MONGODB_URI=mongodb://localhost:27017/pulse

# Groq API Key (required for AI predictions)
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Vector Search (set to true if using MongoDB Atlas with vector search configured)
USE_VECTOR_SEARCH=false

# Map tile style URL (dark theme)
NEXT_PUBLIC_MAP_STYLE=https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json
